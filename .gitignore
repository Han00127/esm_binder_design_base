# 파이썬 캐시
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# 가중치 (절대 커밋 금지 — 경로 참조만)
*.pt
*.pth
*.safetensors
*.ckpt
weights/

# 임시/에디터
.DS_Store
*.swp
*~
.vscode/

# 소스 스크립트·내부 리포트 (로컬 보존, GitHub 미업로드 — 본인만 보유)
data/*.py
report/*
!report/*.png

# ── GitHub 포함(참고): 루트 *.py(코드), report/*.png(figure), docs/*.md,
